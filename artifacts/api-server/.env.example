# Required
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set automatically by Render — defaults to 8080 if absent
PORT=8080

# Optional — controls log verbosity (default: info)
LOG_LEVEL=info

# Optional — only needed if using object storage (image uploads)
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=
